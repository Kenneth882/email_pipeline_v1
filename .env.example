# Supabase (Day 2+) — use project URL + service role (bypasses RLS).
# For direct SQL tooling, prefer the Supavisor pooled connection string.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# HubSpot private app token (CRM contact/deal writes)
# Needs crm.objects.contacts/deals write; crm.schemas.contacts.write to create custom props.
HUBSPOT_ACCESS_TOKEN=

# Unipile API (existing — DSN host:port without https://)
UNPILE_API=
UNPILE_ACCOUNT_ID=
UNPILE_DSN=

# Shared secret YOU choose and attach as the webhook header Unipile-Auth
UNIPILE_WEBHOOK_SECRET=

# Vercel Cron: generate with `openssl rand -hex 32`, set on Vercel Production.
# Cron requests send Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Drip: default true = log intended sends only (no Unipile send). Set false for seed live tests.
DRIP_DRY_RUN=true

# From-address recorded on outbound_messages (must match linked mailbox / alias)
SENT_FROM_ADDRESS=

# Claude (Day 5+ triage)
ANTHROPIC_API_KEY=
