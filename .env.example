# Supabase (Day 2+) — use project URL + service role (bypasses RLS).
# For direct SQL tooling, prefer the Supavisor pooled connection string.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# HubSpot private app token (CRM contact/deal writes)
HUBSPOT_ACCESS_TOKEN=

# Unipile API (existing — DSN host:port without https://)
UNPILE_API=
UNPILE_ACCOUNT_ID=
UNPILE_DSN=

# Shared secret YOU choose and attach as the webhook header Unipile-Auth
# (same value in Unipile webhook headers[] and here). Not a dashboard-generated HMAC key.
UNIPILE_WEBHOOK_SECRET=
